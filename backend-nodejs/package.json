{
  "name": "email-helper-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Email Helper Agent Backend - Node.js (Ollama + Embedded dual-mode)",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "start:ollama": "AI_MODE=ollama node src/index.js",
    "start:embedded": "AI_MODE=embedded node src/index.js",
    "dev": "node --watch src/index.js"
  },
  "dependencies": {
    "express": "^4.21.0",
    "cors": "^2.8.5",
    "ollama": "^0.5.9"
  },
  "optionalDependencies": {
    "node-llama-cpp": "^3.1.1"
  }
}
