## 2. Mã nguồn Frontend Outlook Add-in (Xử lý giao diện)

Tại file `taskpane.ts` (hoặc `.tsx` nếu dùng React) của Outlook Add-in, bạn viết hàm fetch dữ liệu từ Backend và hiển thị lên giao diện.

```typescript
// Gọi hàm này khi người dùng click nút "Phân tích Email" trên Add-in Taskpane
async function onAnalyzeEmailClick() {
  showLoading(true);
  
  const item = Office.context.mailbox.item;
  
  // Lấy nội dung body dưới dạng Text phẳng để giảm token thừa (HTML tags)
  item.body.getAsync(Office.CoercionType.Text, async (result) => {
    if (result.status === Office.AsyncResultStatus.Succeeded) {
      const emailData = {
        subject: item.subject,
        body: result.value
      };

      try {
        // Gọi đến Backend của bạn (Ví dụ chạy ở port 8000)
        const response = await fetch("http://localhost:8000/api/analyze-email", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(emailData)
        });

        const data = await response.json();
        // Nếu Backend trả về string JSON, ta parse nó ra
        const aiResult = typeof data === 'string' ? JSON.parse(data) : data;

        renderOutput(aiResult);
      } catch (error) {
        console.error("Lỗi kết nối AI Backend:", error);
      } finally {
        showLoading(false);
      }
    }
  });
}

// Hiển thị kết quả lên giao diện HTML của Taskpane
function renderOutput(aiResult: any) {
  // 1. Hiển thị Summary
  const summaryContainer = document.getElementById("summary-list");
  summaryContainer.innerHTML = aiResult.summary.map(item => `<li>${item}</li>`).join("");

  // 2. Hiển thị các nút Gợi ý trả lời (Suggested Replies)
  const repliesContainer = document.getElementById("replies-container");
  repliesContainer.innerHTML = ""; // Clear cũ

  aiResult.suggestedReplies.forEach((reply: any) => {
    const btn = document.createElement("button");
    btn.className = "reply-btn";
    btn.innerText = reply.label;
    
    // Khi click vào nút, tự động tạo khung Reply All trong Outlook và chèn text vào
    btn.onclick = () => {
      Office.context.mailbox.item.displayReplyAllForm({
        htmlBody: `<p>${reply.content.replace(/\n/g, '<br>')}</p>`
      });
    };
    
    repliesContainer.appendChild(btn);
  });
}

```

