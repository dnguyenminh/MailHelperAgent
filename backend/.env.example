# Email Helper Agent Backend — Environment Configuration
# Copy this file to .env and adjust values as needed.

# AI Mode: "ollama" (default) or "embedded"
AI_MODE=ollama

# Ollama settings (when AI_MODE=ollama)
OLLAMA_MODEL=qwen2.5:7b-instruct-q4_K_M
OLLAMA_HOST=http://localhost:11434

# Embedded model settings (when AI_MODE=embedded)
# MODEL_PATH=./models/qwen2.5-3b-instruct-q4_k_m.gguf

# Server
# PORT=8000
